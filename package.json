{
  "name": "SharedAccount",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "npx @react-native-community/cli run-android",
    "ios": "npx @react-native-community/cli run-ios",
    "lint": "npx eslint .",
    "format:check": "npx prettier --check .",
    "format": "npx prettier --write .",
    "typecheck": "npx tsc --noEmit",
    "start": "npx @react-native-community/cli start --client-logs",
    "test": "npx jest",
    "clean": "rm -rf node_modules && rm -rf ios/Pods && rm -rf Gemfile.lock && bundle install && rm -rf ios/Podfile.lock && rm -rf yarn.lock && yarn install && cd ios && pod install && cd ..",
    "prepare": "npx husky",
    "storybook-generate": "sb-rn-get-stories",
    "precommit": "yarn lint && yarn format && yarn typecheck",
    "hygen-generate": "npx hygen component with-prompt"
  },
  "dependencies": {
    "@react-native-picker/picker": "^2.11.0",
    "@react-navigation/bottom-tabs": "^7.2.1",
    "@react-navigation/native": "^7.0.15",
    "@realm/react": "^0.11.0",
    "luxon": "^3.5.0",
    "react": "19.0.0",
    "react-hook-form": "7.54.2",
    "react-native": "0.78.0",
    "react-native-file-access": "3.1.1",
    "react-native-gifted-charts": "^1.4.58",
    "react-native-keyboard-controller": "1.16.8",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-modal-datetime-picker": "18.0.0",
    "react-native-screens": "^4.9.2",
    "realm": "12.14.1",
    "ts-money": "0.4.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@faker-js/faker": "^9.6.0",
    "@gorhom/bottom-sheet": "^5.1.2",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/cli": "15.0.1",
    "@react-native-community/cli-platform-android": "15.0.1",
    "@react-native-community/cli-platform-ios": "15.0.1",
    "@react-native-community/datetimepicker": "^8.3.0",
    "@react-native-community/slider": "^4.5.6",
    "@react-native/babel-preset": "0.78.0",
    "@react-native/eslint-config": "0.78.0",
    "@react-native/metro-config": "0.78.0",
    "@react-native/typescript-config": "0.78.0",
    "@storybook/addon-ondevice-controls": "^8.6.1",
    "@storybook/react-native": "^8.6.1",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.13",
    "@types/luxon": "^3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19",
    "@types/react-test-renderer": "^19.0.0",
    "babel-loader": "^8.4.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.19.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-native": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^29.6.3",
    "prettier": "3.5.3",
    "react-dom": "19.0.0",
    "react-native-gesture-handler": "^2.24.0",
