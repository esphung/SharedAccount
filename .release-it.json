{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "github": {
    "release": true,
    "web": true,
    "autoGenerate": true,
    "releaseName": "v${version}"
  },
  "git": {
    "commit": true,
    "commitMessage": "chore: release v${version}"
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:bump": "sh ./.scripts/increase-build-number.sh ${version} ${latestVersion}"
  }
}
