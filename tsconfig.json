{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@components/*": ["./src/components/*"],
      "types/*": ["./src/types/*"],
      "@builders/*": ["./src/builders/*"],
      "@themes/*": ["./src/themes/*"],
      "@helpers/*": ["./src/helpers/*"],
      "@screens/*": ["./src/screens/*"],
      "@navigators/*": ["./src/navigators/*"]
    }
  },
  "jsx": "react-native",
  "exclude": [
    "./node_modules",
    "./android",
    "./ios",
    "./.storybook/storybook.requires.ts"
  ]
}
